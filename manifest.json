{
  "manifest_version": 3,
  "name": "SLOW LLM",
  "version": "1.0",
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://claude.ai/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "500": "logo.png"
  }
}
